{
    "name": "ft_transcendence-backend",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "start": "nest start",
        "start:dev": "nest start --watch",
        "build": "nest build",
        "start:prod": "node dist/main.js",
        "clean": "rm -rf dist && find src -name '*.js' -delete",
        "fclean": "rm -rf dist node_modules && find src -name '*.js' -delete && npm cache clean --force",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.3.0",
        "@nestjs/core": "^10.4.22",
        "@nestjs/jwt": "^10.0.0",
        "@nestjs/mapped-types": "*",
        "@nestjs/passport": "^10.0.0",
        "@nestjs/platform-express": "^10.0.0",
        "@prisma/client": "^5.21.1",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "passport": "^0.6.0",
        "passport-42": "^1.2.6",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/testing": "^10.4.22",
        "@types/bcrypt": "^5.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.5",
        "@types/passport-42": "^1.1.2",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.35",
        "@types/pg": "^8.18.0",
        "jest": "^30.3.0",
        "prisma": "^5.21.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
