// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  id           String   @id @default(uuid())
  username     String   @default("User")
  name         String?
  email        String   @unique
  phone        String?
  businessName String?  @map("business_name")
  businessAddress String? @map("business_address")
  logoUrl      String?  @map("logo_url")
  defaultCurrency String? @default("USD") @map("default_currency")
  taxRate      Decimal? @default(0) @db.Decimal(5, 2) @map("tax_rate")
  password     String?
  passwordHash String?
  intraId      String?  @unique
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  xp           Int      @default(0)
  level        Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  clients      Client[]
  projects     Project[]
  invoices     Invoice[]
  notifications Notification[]
  proposals    Proposal[]
  achievements UserAchievement[]
  badges       UserBadge[]
  notes        Note[]
  events       Event[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@index([userId])
  @@map("clients")
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  budget      Decimal       @default(0) @db.Decimal(10, 2)
  deadline    DateTime?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  userId      String        @map("user_id")
  clientId    String        @map("client_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  proposals   Proposal[]

  @@index([userId])
  @@index([clientId])
  @@map("projects")
}

model Proposal {
  id         String         @id @default(uuid())
  title      String
  amount     Decimal        @db.Decimal(10, 2)
  status     ProposalStatus @default(DRAFT)
  notes      String?
  validUntil DateTime?      @map("valid_until")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt      @map("updated_at")

  userId     String         @map("user_id")
  projectId  String         @map("project_id")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@map("proposals")
}

model Invoice {
  id        String        @id @default(uuid())
  amount    Decimal       @db.Decimal(10, 2)
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime?     @map("due_date")
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt      @map("updated_at")

  userId    String        @map("user_id")
  projectId String        @map("project_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([userId])
  @@index([projectId])
  @@map("invoices")
}

model Payment {
  id        String   @id @default(uuid())
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  notes     String?
  paidAt    DateTime @default(now()) @map("paid_at")

  invoiceId String   @map("invoice_id")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String
  tags      String[]
  color     String   @default("default")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        String
  time        String
  endDate     String?  @map("end_date")
  endTime     String?  @map("end_time")
  clientTag   String?
  projectTag  String?
  description String?
  eventType   String?  @map("event_type")
  priority    String?
  location    String?
  externalLink String? @map("external_link")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("events")
}

// =============================================================================
// ENUMS
// =============================================================================

enum ProjectStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  title     String?
  message   String
  read      Boolean  @default(false)
  type      String   @default("info")
  targetType String? @map("target_type")
  targetId  String?  @map("target_id")
  createdAt DateTime @default(now()) @map("created_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model UserAchievement {
  id        String   @id @default(uuid())
  type      String   // e.g. "FIRST_PROJECT" or "LOYAL_CLIENT_3"
  name      String
  earnedAt  DateTime @default(now()) @map("earned_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type]) // User can only earn an achievement type once
  @@map("user_achievements")
}

model UserBadge {
  id        String   @id @default(uuid())
  type      String   // e.g. "HIGH_ROLLER" or "EARLY_BIRD"
  name      String
  earnedAt  DateTime @default(now()) @map("earned_at")

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type]) // User can only earn a badge type once
  @@map("user_badges")
}
