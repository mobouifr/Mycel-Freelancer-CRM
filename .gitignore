# =============================================================================
# FREELANCER CRM — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT FILES — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.staging
.env.production
.env.*.local
*.pem
*.key
*.cert

# -----------------------------------------------------------------------------
# DEPENDENCIES
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# BUILD OUTPUT
# -----------------------------------------------------------------------------
dist/
build/
.next/
out/

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# RUNTIME & TEMP
# -----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
tmp/
.tmp/

# -----------------------------------------------------------------------------
# COVERAGE & TESTING
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
# Ignore local data volumes (if you mount them in docker-compose)
.docker-data/
postgres-data/

# -----------------------------------------------------------------------------
# UPLOADS (user-generated files stored locally in dev)
# -----------------------------------------------------------------------------
uploads/
!uploads/.gitkeep

# -----------------------------------------------------------------------------
# PRISMA
# -----------------------------------------------------------------------------
# Generated Prisma Client (regenerated on npm install / prisma generate)
node_modules/.prisma/

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
.turbo/
.cache/
*.tsbuildinfo
