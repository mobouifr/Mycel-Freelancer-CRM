# FREELANCER CRM — Environment Variables
# Copy this file:  cp .env.example .env
# Then fill in the values below. NEVER commit .env to git.

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
# Environment: development | staging | production
NODE_ENV=development

# Backend API port (used by NestJS and Docker)
PORT=3001

# Frontend dev server port (Vite, not used in production)
FRONTEND_PORT=3000

# Allowed CORS origins (comma-separated, used by backend)
# Local: http://localhost:3000  |  Prod: https://crm.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE — PostgreSQL 16
# -----------------------------------------------------------------------------
# Connection string used by Prisma ORM (backend)
DATABASE_URL=postgresql://postgres:password@localhost:5432/freelancer_crm?schema=public

# Individual DB vars used by Docker Compose to initialize PostgreSQL container
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=freelancer_crm

# -----------------------------------------------------------------------------
# AUTHENTICATION — JWT
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens (min 32 chars, random string)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE-ME-generate-a-64-char-random-string

# Token expiration (e.g., 15m, 1h, 7d)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiration
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt salt rounds for password hashing
BCRYPT_SALT_ROUNDS=12

# -----------------------------------------------------------------------------
# FRONTEND — Vite (prefixed with VITE_ to be exposed to client)
# -----------------------------------------------------------------------------
# Base URL for API calls from the browser
# Local: http://localhost:3001/api  |  Docker: /api (proxied by Nginx)
VITE_API_URL=http://localhost:3001/api

# WebSocket URL for real-time notifications
VITE_WS_URL=http://localhost:3001

# App name shown in UI
VITE_APP_NAME=Freelancer CRM

# -----------------------------------------------------------------------------
# FILE UPLOADS
# -----------------------------------------------------------------------------
# Max file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Upload storage directory (local or cloud path)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# OPTIONAL: EMAIL SERVICE (Nodemailer)
# -----------------------------------------------------------------------------
# SMTP config for sending invoices, proposals, and notifications
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password


# -----------------------------------------------------------------------------
# OPTIONAL: PDF GENERATION
# -----------------------------------------------------------------------------
# Puppeteer/Chromium path (auto-detected in most cases)
# Set explicitly if running in Alpine/Docker
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# -----------------------------------------------------------------------------
# LOGGING & MONITORING
# -----------------------------------------------------------------------------
# Log level: debug | info | warn | error
LOG_LEVEL=debug

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Grafana admin credentials (http://localhost:3002)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE-ME-set-a-strong-password
GF_AUTH_ANONYMOUS_ENABLED=false
GF_USERS_ALLOW_SIGN_UP=false

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Max requests per minute per IP
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
