# =============================================================================
# FREELANCER CRM — Environment Variables Template (development)
# Copy this file: cp .env.example .env
# Fill in real values. NEVER commit .env to git.
# For production: cp .env.prod.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# Public URL of the frontend — used by backend for CORS and OAuth redirects
FRONTEND_URL=https://localhost

# Allowed CORS origins (comma-separated). Only needed if you run the frontend
# on a non-standard port. Leave blank to use the FRONTEND_URL default.
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Database — PostgreSQL 16
# -----------------------------------------------------------------------------
# Individual vars used by Docker Compose to initialise the PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE-ME-db-password
POSTGRES_DB=freelancer_crm

# Prisma connection string (docker-compose builds this from the vars above;
# set it here for local CLI usage: npx prisma migrate dev, npx prisma studio)
DATABASE_URL=postgresql://postgres:CHANGE-ME-db-password@localhost:5432/freelancer_crm?schema=public

# -----------------------------------------------------------------------------
# Authentication — JWT
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE-ME-generate-a-64-char-random-hex-string
JWT_ACCESS_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=12

# -----------------------------------------------------------------------------
# Frontend — Vite (values are baked into the JS bundle at build time)
# In Docker, Nginx proxies /api → backend, so a relative path is correct.
# -----------------------------------------------------------------------------
VITE_API_URL=/api
VITE_APP_NAME=Mycel

# -----------------------------------------------------------------------------
# 42 School OAuth
# Create your app at: https://profile.intra.42.fr/oauth/applications
# Redirect URI registered in your 42 app must match FORTYTWO_CALLBACK_URL exactly.
# -----------------------------------------------------------------------------
FORTYTWO_CLIENT_ID=CHANGE-ME-your-42-client-id
FORTYTWO_CLIENT_SECRET=CHANGE-ME-your-42-client-secret
FORTYTWO_CALLBACK_URL=http://localhost:3001/api/auth/42/callback

# -----------------------------------------------------------------------------
# AI — DeepSeek LLM
# Get your key at: https://platform.deepseek.com
# This key is server-side only — never exposed to the browser.
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=CHANGE-ME-your-deepseek-api-key

# -----------------------------------------------------------------------------
# Monitoring — Grafana (accessible at https://localhost/grafana)
# GF_SECURITY_ADMIN_PASSWORD has no default — docker-compose will refuse to
# start without it (enforced with the :? operator in docker-compose.yml).
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE-ME-grafana-admin-password
GF_AUTH_ANONYMOUS_ENABLED=false
GF_USERS_ALLOW_SIGN_UP=false
