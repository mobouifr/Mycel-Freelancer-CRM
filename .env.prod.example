# =============================================================================
# FREELANCER CRM — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# Run:  cp .env.prod.example .env
# NEVER commit the real .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3001

# Your public domain name — used by nginx SSL config and CORS
DOMAIN=example.com

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_USER=crm_prod
POSTGRES_PASSWORD=CHANGE-ME-strong-random-password
POSTGRES_DB=freelancer_crm

# Full connection string — docker-compose.prod.yml builds this automatically
# from the variables above, so you only need it here for local tooling (prisma, etc.)
DATABASE_URL=postgresql://crm_prod:CHANGE-ME-strong-random-password@localhost:5432/freelancer_crm?schema=public

# ---------------------------------------------------------------------------
# JWT — generate with:  openssl rand -hex 64
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE-ME-generate-a-64-char-random-hex-string
JWT_ACCESS_EXPIRES_IN=1d

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12

# ---------------------------------------------------------------------------
# CORS — must include your production domain
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://example.com,https://www.example.com
FRONTEND_URL=https://example.com

# ---------------------------------------------------------------------------
# Frontend (Vite) — baked into the JS bundle at build time
# ---------------------------------------------------------------------------
VITE_API_URL=/api
VITE_APP_NAME=Mycel

# ---------------------------------------------------------------------------
# OAuth — 42 School
# ---------------------------------------------------------------------------
FORTYTWO_CLIENT_ID=CHANGE-ME-your-42-client-id
FORTYTWO_CLIENT_SECRET=CHANGE-ME-your-42-client-secret
FORTYTWO_CALLBACK_URL=https://example.com/api/auth/42/callback

# ---------------------------------------------------------------------------
# AI — DeepSeek LLM
# Get your key at: https://platform.deepseek.com
# This key is server-side only — never exposed to the browser.
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=CHANGE-ME-your-deepseek-api-key

# ---------------------------------------------------------------------------
# Monitoring — Grafana
# Variable names must match docker-compose.yml (GF_SECURITY_ADMIN_*)
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE-ME-strong-grafana-password
GF_AUTH_ANONYMOUS_ENABLED=false
GF_USERS_ALLOW_SIGN_UP=false
